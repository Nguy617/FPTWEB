@model FPTPlay.Models.Movie

@{
    ViewData["Title"] = Model.Title;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title - FPT Play</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #000;
            color: white;
            font-family: Arial, sans-serif;
        }

        .container {
            max-width: 1200px;
            margin: auto;
            padding: 20px;
        }

        .video-player {
            width: 100%;
            max-height: 70vh;
            background: #111;
        }

        .movie-info {
            margin-top: 30px;
        }

        .back-btn {
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="javascript:history.back()" class="btn btn-outline-light back-btn">← Quay lại</a>

        <h1 class="mb-3">@Model.Title</h1>

        @if (!string.IsNullOrEmpty(Model.VideoUrl))
        {
            <video class="video-player" controls autoplay poster="@Model.PosterUrl">
                <source src="@Model.VideoUrl" type="video/mp4">
                Trình duyệt không hỗ trợ video.
            </video>
        }
        else
        {
            <div class="alert alert-warning text-center">
                Phim chưa có video. Vui lòng quay lại sau!
            </div>
        }

        <div class="movie-info">
            <p><strong>Mô tả:</strong> @(Model.Description ?? "Không có mô tả")</p>
            <p><strong>Thể loại:</strong> @(Model.Category?.Name ?? "Chưa phân loại")</p>
            <p><strong>Năm:</strong> 2026 • FULLHD • @(Model.Duration.HasValue ? $"{Model.Duration} phút" : "Chưa cập nhật")</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>