@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Dashboard";
}

<style>
    .stat-card {
        background: #25262b;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #373a40;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        background: rgba(241, 90, 36, 0.1);
        color: #f15a24;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .stat-info h3 {
        margin: 0;
        font-size: 1.8rem;
        font-weight: bold;
    }

    .stat-info p {
        margin: 0;
        color: #adb5bd;
        font-size: 0.9rem;
    }
</style>

<div class="row g-4 mb-4">

    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-info">
                <p>Tổng số Phim</p>
                <h3>@ViewBag.TotalMovies</h3>
            </div>
            <div class="stat-icon">
                <i class="fas fa-film"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-info">
                <p>Danh mục</p>
                <h3>@ViewBag.TotalCategories</h3>
            </div>
            <div class="stat-icon">
                <i class="fas fa-list"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-info">
                <p>Người dùng</p>
                <h3>@ViewBag.TotalUsers</h3>
            </div>
            <div class="stat-icon">
                <i class="fas fa-users"></i>
            </div>
        </div>
    </div>

</div>

<div class="card bg-dark border-secondary">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Hoạt động gần đây</h5>
        <button class="btn btn-sm btn-outline-light">Xem thêm</button>
    </div>

    <div class="card-body">
        <p class="text-secondary text-center py-4">
            Chưa có hoạt động nào được ghi nhận.
        </p>
    </div>
</div>